{
  "manifest_version": 3,
  "name": "VSL Downloader PRO",
  "version": "5.0",

  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "webRequest"
  ],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "core/background.js"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}