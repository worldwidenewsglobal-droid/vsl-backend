{
  "manifest_version": 3,
  "name": "VSL Downloader PRO",
  "version": "2.0",
  "permissions": ["webRequest", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}